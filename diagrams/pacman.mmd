flowchart TD

A[Pacman.Update] --> AI{aiControlled?}
AI -- No --> B[HandleInput<br/>WASD / Arrow keys]
B --> C["Movement.SetDirection(dir)"]
AI -- Yes --> AGENT["PacmanAgent.OnActionReceived<br/>Movement.SetDirection(dir)"]
AGENT --> C

C --> OCC{"Occupied(dir)? BoxCast on obstacleLayer"}
OCC -- Yes --> QUEUE[Queue as nextDirection]
OCC -- No --> SET[direction = dir]
QUEUE --> ROT
SET --> ROT[UpdateRotation: face movement.direction]

ROT --> FU[Movement.FixedUpdate]
FU --> MP[rb.MovePosition<br/>speed * speedMultiplier * dt * direction]
MP --> RETRY[Movement.Update: retry nextDirection if set]

RETRY --> TRIG{Unity trigger / collision}
TRIG -- Pellet --> PE[Pellet.Eat -> GameManager.PelletEaten]
TRIG -- PowerPellet --> PPE[PowerPellet.Eat -> GameManager.PowerPelletEaten]
TRIG -- Ghost --> GH[Ghost.OnCollisionEnter2D<br/>GhostEaten or PacmanEaten]
TRIG -- Passage --> WARP[Passage: teleport to connection]
TRIG -- None --> A

PE --> A
PPE --> A
WARP --> A
GH --> A
