stateDiagram-v2
    [*] --> MainMenu

    MainMenu --> Playing : StartGame()

    Playing --> Paused : PauseGame()
    Paused --> Playing : ResumeGame()
    Paused --> MainMenu : QuitToMenu()
    Paused --> Playing : RestartGame()

    Playing --> LevelComplete : AllPelletsEaten
    LevelComplete --> Playing : LoadNextLevel()

    Playing --> PacManDied : GhostCaughtPacMan
    PacManDied --> Playing : RespawnPacMan (Lives > 0)
    PacManDied --> GameOver : NoLivesRemaining

    GameOver --> MainMenu : ReturnToMenu()
    GameOver --> Playing : RestartGame()

    MainMenu --> [*] : QuitGame()
    GameOver --> [*] : QuitGame()
