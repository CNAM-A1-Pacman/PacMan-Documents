classDiagram

    class PacmanAgent {
        <<MonoBehaviour : Agent>>
        - gameManager : GameManager
        - movement : Movement
        - pacman : Pacman
        - rewards : PacmanRewardHandler
        + Initialize()
        + OnEpisodeBegin()
        + CollectObservations(VectorSensor)
        + OnActionReceived(ActionBuffers)
        + Heuristic(ActionBuffers)
    }

    class PacmanRewardHandler {
        <<C# Class>>
        + PelletReward / PowerPelletReward
        + GhostReward / DeathPenalty
        + RoundCompleteReward / StepPenalty
        + OnPelletEaten() float
        + OnGhostEaten() float
        + OnStep(distanceDelta) float
    }

    class TrainingManager {
        <<MonoBehaviour>>
        - pacman : Pacman
        - gameManager : GameManager
        - agent : PacmanAgent
        - modeDetector : TrainingModeDetector
        - timeScale : TimeScaleController
        - ui : TrainingUIController
        - activator : AgentActivator
        - aiActive : bool
        + TryInitialize()
    }

    class TrainingModeDetector {
        <<C# Class>>
        + IsTraining : bool
        + ShouldAutoEnable : bool
        + Detect(BehaviorParameters)
    }

    class AgentActivator {
        <<C# Class>>
        - pacman : Pacman
        - agent : PacmanAgent
        - decisionRequester : Behaviour
        + SetActive(bool)
    }

    class TimeScaleController {
        <<C# Class>>
        + ApplyFor(aiActive, isTraining)
    }

    %% TrainingUIController shows MANUAL / AUTOPILOT / TRAINING
    class TrainingUIController {
        <<C# Class>>
        + Refresh(aiActive, isTraining)
    }

    TrainingManager *-- TrainingModeDetector
    TrainingManager *-- AgentActivator
    TrainingManager *-- TimeScaleController
    TrainingManager *-- TrainingUIController
    TrainingManager --> PacmanAgent
    PacmanAgent *-- PacmanRewardHandler
    AgentActivator ..> Pacman : sets aiControlled
    AgentActivator ..> PacmanAgent : enable/disable
    PacmanAgent ..> Movement : SetDirection
    PacmanAgent ..> GameManager : subscribe events -> rewards
    TrainingModeDetector ..> BehaviorParameters : Model == null => training
