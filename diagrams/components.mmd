graph LR

subgraph Core["Core Game (Pacman scene)"]
    GM[GameManager : IGameEvents<br/>singleton]
    SM[ScoreManager]
    LV[LivesManager]
    UI[UIManager]
    Pause[PauseManager]
end

subgraph PlayerEntities["Entities"]
    Pac[Pacman]
    Mov[Movement : IMovable]
    Pel[Pellet]
    PPel[PowerPellet : Pellet]
    Node[Node]
    Pass[Passage]
end

subgraph Ghosts["Ghost AI (per-ghost components)"]
    Ghost[Ghost]
    GB[GhostBehavior : IDurableBehavior]
    Chase["Chase variants<br/>GhostChase / Ambusher /<br/>Flanker / Boo"]
    Scat[GhostScatter]
    Fright[GhostFrightened]
    Home[GhostHome]
    Eyes[GhostEyes]
    Recov[GhostWallRecovery]
end

subgraph Settings["Settings & Difficulty"]
    GS[GameSettings : static]
    GSA[GameSettingsApplier]
    Diff[DifficultyScoreCalculator]
    Modal[DifficultyModal]
end

subgraph Menus["Menus & Scenes"]
    Menu[Menu - PageAccueil]
    MapSel[MapSelectionMenu - ChoixTypeJeu]
    Loading[LoadingBar]
end

subgraph MapEditor["Map Editor subsystem"]
    MEM[MapEditorManager]
    MEU[MapEditorUI]
    MLoad[MapLoader]
    MData[MapData / MapRepository /<br/>MapSession / MapValidator]
end

subgraph ML["ML-Agents / Autopilot"]
    TM[TrainingManager]
    Agent[PacmanAgent : Agent]
    Activator[AgentActivator]
end

%% Core wiring
GM --> SM
GM --> LV
GM --> UI
GM --> Pac
GM --> Ghost
GM --> Pel

%% Entity composition
Pac --> Mov
Ghost --> Mov
PPel -.extends.-> Pel
Pel -- Eat() --> GM
Mov -- BoxCast --> Node

%% Ghost behaviors
Ghost --> GB
GB -.base of.-> Chase
GB -.base of.-> Scat
GB -.base of.-> Fright
GB -.base of.-> Home
Ghost --> Eyes
Ghost --> Recov
Fright -- GhostEaten() --> GM

%% Settings flow
Modal -- writes --> GS
GSA -- reads --> GS
GM -- reads --> GS
Diff -- reads --> GS
GSA -- applies speed/delay --> Ghost
GSA -- applies speed --> Pac

%% Menu flow
Menu --> MapSel
MapSel --> Modal
Modal -- loads --> MEM
Modal -- MapSession --> MLoad

%% Map editor
MEM --> MEU
MEM --> MData
MLoad -- builds tilemap/nodes/pellets --> Core

%% ML
TM --> Agent
TM --> Activator
Activator -- toggles aiControlled --> Pac
Agent --> Mov
Agent -- subscribes events --> GM
