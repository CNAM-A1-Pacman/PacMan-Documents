classDiagram

    %% ======================= Interfaces =======================
    class IGameEvents {
        <<interface>>
        + PelletEaten(Pellet)
        + PowerPelletEaten(PowerPellet)
        + GhostEaten(Ghost)
        + PacmanEaten()
    }

    class IMovable {
        <<interface>>
        + direction : Vector2
        + speedMultiplier : float
    }

    class IBehavior {
        <<interface>>
        + Enable()
        + Disable()
    }

    class IDurableBehavior {
        <<interface>>
        + duration : float
        + Enable(duration : float)
    }

    IBehavior <|-- IDurableBehavior

    %% ======================= Managers =======================
    class GameManager {
        <<MonoBehaviour>>
        + Instance : GameManager$
        - ghosts : Ghost[]
        - pacman : Pacman
        - pellets : Transform
        + trainingMode : bool
        - scoreManager : ScoreManager
        - livesManager : LivesManager
        - uiManager : UIManager
        - ghostMultiplier : int
        - currentRound : int
        + score : int
        + lives : int
        + OnPelletEatenEvent : Action~Pellet~
        + OnPowerPelletEatenEvent : Action~PowerPellet~
        + OnGhostEatenEvent : Action~Ghost~
        + OnPacmanEatenEvent : Action
        + OnRoundCompleteEvent : Action
        + NewGame()
        - NewRound()
        - ApplyRoundSpeeds()
        - ResetState()
        - GameOver()
        + PacmanEaten()
        + GhostEaten(Ghost)
        + PelletEaten(Pellet)
        + PowerPelletEaten(PowerPellet)
        + HasRemainingPellets() bool
        + ResetForTraining()
    }

    class ScoreManager {
        <<C# Class>>
        - scoreText : Text
        + Score : int
        + SetScore(int)
        + Add(int)
    }

    class LivesManager {
        <<C# Class>>
        - livesText : Text
        + Lives : int
        + SetLives(int)
        + Decrement() int
    }

    class UIManager {
        <<C# Class>>
        - gameOverText : Text
        - gameOverPanel : GameObject
        + ShowGameOver()
        + HideGameOver()
    }

    %% ======================= Movement / Grid =======================
    class Movement {
        <<MonoBehaviour>>
        + speed : float
        + speedMultiplier : float
        + initialDirection : Vector2
        + obstacleLayer : LayerMask
        + rb : Rigidbody2D
        + direction : Vector2
        + nextDirection : Vector2
        + startingPosition : Vector3
        + ResetState()
        + SetDirection(Vector2, forced : bool)
        + Occupied(Vector2) bool
    }

    class Node {
        <<MonoBehaviour>>
        + obstacleLayer : LayerMask
        + availableDirections : List~Vector2~
        + SetDirections(List~Vector2~)
        - CheckAvailableDirection(Vector2)
    }

    class Passage {
        <<MonoBehaviour>>
        + connection : Transform
    }

    class AnimatedSprite {
        <<MonoBehaviour>>
        + sprites : Sprite[]
        + animationTime : float
        + loop : bool
        + Restart()
        - Advance()
    }

    %% ======================= Pac-Man =======================
    class Pacman {
        <<MonoBehaviour>>
        + movement : Movement
        + aiControlled : bool
        - HandleInput()
        - UpdateRotation()
        + ResetState()
        + DeathSequence()
    }

    %% ======================= Pellets =======================
    class Pellet {
        <<MonoBehaviour>>
        + points : int
        - _gameEvents : IGameEvents
        + Init(IGameEvents)
        + GetPointsWhenEaten() int
        # Eat()
        - OnTriggerEnter2D(Collider2D)
    }

    class PowerPellet {
        <<MonoBehaviour>>
        + duration : float
    }

    Pellet <|-- PowerPellet

    %% ======================= Ghosts =======================
    class Ghost {
        <<MonoBehaviour>>
        + points : int
        + movement : Movement
        + home : GhostHome
        + scatter : GhostScatter
        + chase : GhostBehavior
        + frightened : GhostFrightened
        + initialBehavior : GhostBehavior
        + target : Transform
        + ResetState()
        + SetPosition(Vector3)
    }

    class GhostBehavior {
        <<abstract MonoBehaviour>>
        # ghost : Ghost
        + duration : float
        + SetDuration(float)
        + Enable()
        + Enable(duration : float)
        + Disable()
        # OnTriggerEnter2D(Collider2D)*
        # OnDisable()*
        # CanMove() bool
        # HasAvailableDirections(Node) bool
        # IsAvailableDirection(Node, Vector2) bool
    }

    %% Chase variants (auto-detected into Ghost.chase):
    %%   GhostChase = Blinky (aim straight at target)
    %%   GhostChaseAmbusher = Pinky (aim ahead of Pac-Man)
    %%   GhostChaseBoo = Inky (reverse when faced head-on)
    %%   GhostChaseFlanker = Clyde (pivot off Blinky)
    class GhostChase {
        <<MonoBehaviour>>
    }
    class GhostChaseAmbusher {
        <<MonoBehaviour>>
        + lookAheadTiles : float
    }
    class GhostChaseFlanker {
        <<MonoBehaviour>>
        + lookAheadTiles : float
        + blinky : Ghost
    }
    class GhostChaseBoo {
        <<MonoBehaviour>>
    }
    class GhostScatter {
        <<MonoBehaviour>>
    }
    class GhostFrightened {
        <<MonoBehaviour>>
        + body : SpriteRenderer
        + blue : SpriteRenderer
        + white : SpriteRenderer
        + Init(IGameEvents)
        - Eaten()
        - Flash()
    }
    class GhostHome {
        <<MonoBehaviour>>
        + inside : Transform
        + outside : Transform
        - ExitTransition() IEnumerator
    }

    GhostBehavior <|-- GhostChase
    GhostBehavior <|-- GhostChaseAmbusher
    GhostBehavior <|-- GhostChaseFlanker
    GhostBehavior <|-- GhostChaseBoo
    GhostBehavior <|-- GhostScatter
    GhostBehavior <|-- GhostFrightened
    GhostBehavior <|-- GhostHome

    class GhostEyes {
        <<MonoBehaviour>>
        + eyesUp/Down/Left/Right : Sprite
        - UpdateEyeSprite()
    }

    class GhostWallRecovery {
        <<MonoBehaviour>>
        + Recover(Movement)
    }

    class GhostKind {
        <<enum>>
        Blinky
        Pinky
        Inky
        Clyde
    }

    class GhostKindResolver {
        <<static>>
        + Count : int$
        + GameObjectName(GhostKind) string$
        + TryResolve(string, out GhostKind) bool$
    }

    %% ======================= Settings / Difficulty =======================
    class GameSettings {
        <<static>>
        + PacmanSpeedLevel : int$
        + GhostSpeedLevel : int$
        + PowerPelletDurationLevel : int$
        + GhostPrisonDurationLevel : int$
        + AutopilotEnabled : bool$
        + IsGhostEnabled(GhostKind) bool$
        + SetGhostEnabled(GhostKind, bool)$
        + EnabledGhostCount : int$
        + PacmanSpeed : float$
        + GhostSpeed : float$
        + PowerPelletDuration : float$
        + ComputeGhostSpeedForRound(int) float$
        + ComputePacManSpeedForRound(int) float$
    }

    class GameSettingsApplier {
        <<MonoBehaviour>>
        - ApplyPacmanSpeed()
        - ApplyGhostSpeed()
        - ApplyPelletDuration()
        - ApplyGhostExitDelays()
    }

    class DifficultyScoreCalculator {
        <<static>>
        + ComputeDifficultyIndex(...) int$
        + GetDifficultyLabel(int) string$
        + GetDifficultyColorHex(int) string$
    }

    %% ======================= Interface realizations =======================
    IGameEvents <|.. GameManager
    IMovable <|.. Movement
    IDurableBehavior <|.. GhostBehavior

    %% ======================= Composition / dependencies =======================
    GameManager "1" *-- "1" ScoreManager
    GameManager "1" *-- "1" LivesManager
    GameManager "1" *-- "1" UIManager
    GameManager "1" --> "0..*" Ghost : controls
    GameManager "1" --> "1" Pacman : controls
    GameManager "1" --> "0..*" Pellet : tracks

    Pacman "1" *-- "1" Movement
    Ghost "1" *-- "1" Movement
    Ghost "1" o-- "1..*" GhostBehavior : components
    Ghost "1" --> "1" Pacman : target
    GhostFrightened ..> IGameEvents : notifies GhostEaten
    GhostEyes ..> Movement : reads direction
    Pellet ..> GameManager : PelletEaten()
    PowerPellet ..> GameManager : PowerPelletEaten()

    GameManager ..> GameSettings : reads speeds / round
    GameSettingsApplier ..> GameSettings : applies
    GameManager ..> GhostKindResolver : filter enabled
    GameSettings ..> GhostKind
    DifficultyScoreCalculator ..> GameSettings
