graph TB
    subgraph Project["Unity Project (Assets/)"]

        subgraph Scenes["Scenes/"]
            Accueil[PageAccueil<br/>Menu, LoadingBar]
            Choix[ChoixTypeJeu<br/>MapSelectionMenu, DifficultyModal]
            Editor[MapEditor<br/>MapEditorManager + MapEditorUI]
            Game[Pacman<br/>main game]
            Auto[Pacman_Autopilot<br/>game + ML autopilot]
            Train[Pacman_Training<br/>game + ML training]
        end

        subgraph GameHierarchy["Pacman scene hierarchy"]
            GMObj[GameObject: GameManager<br/>GameManager.cs]
            Applier[GameObject: GameSettingsApplier]
            PauseObj[GameObject: PauseManager]
            MapLoaderObj[GameObject: MapLoader]
            CanvasUI[Canvas: Score / Lives / Round / GameOver]

            Grid[Grid + Tilemaps: Walls / Pellets / Nodes]
            PelletsObj[GameObject: Pellets<br/>Pellet + PowerPellet]
            NodesObj[Nodes: Node.cs]
            PassageObj[Passages: Passage.cs]

            PacObj[GameObject: Pacman<br/>Pacman + Movement + AnimatedSprite]
            G1[Ghost_Blinky<br/>Ghost + GhostChase]
            G2[Ghost_Pinky<br/>Ghost + GhostChaseAmbusher]
            G3[Ghost_Inky<br/>Ghost + GhostChaseBoo]
            G4[Ghost_Clyde<br/>Ghost + GhostChaseFlanker]
        end

        subgraph Prefabs["Prefabs/"]
            PfBase[Ghost_Base - variant parent]
            PfGhosts[Ghost_Blinky/Pinky/Inky/Clyde]
            PfPac[Pacman]
            PfPellet[Pellet / PowerPellet]
            PfNode[Node]
        end

        subgraph Scripts["Scripts/"]
            SCore[Root: GameManager, Pacman, Ghost,<br/>Movement, Pellet, Node, *Manager]
            SInt[Interfaces/: IGameEvents, IMovable,<br/>IBehavior, IDurableBehavior]
            SMap[MapEditor/: MapData, MapRepository,<br/>MapLoader, MapValidator, NodeGenerator...]
            SML[ML/: PacmanAgent, TrainingManager,<br/>AgentActivator, reward/detector helpers]
        end

        subgraph Assets["Data assets"]
            Onnx[ML-Agents/Models/*.onnx]
            PPO[ML-Agents/config/pacman_ppo.yaml]
            SecondMap[StreamingAssets/Maps/secondMap.json]
            CustomMaps[persistentData/CustomMaps/*.json]
        end
    end

    Accueil --> Choix
    Choix --> Editor
    Choix --> Game
    Choix --> Auto
    Editor --> Game

    Game --> GMObj
    Game --> Applier
    Game --> PauseObj
    Game --> MapLoaderObj
    Game --> CanvasUI
    Game --> Grid
    Grid --> PelletsObj
    Grid --> NodesObj
    Grid --> PassageObj
    Game --> PacObj
    Game --> G1
    Game --> G2
    Game --> G3
    Game --> G4

    PfBase -.variant.-> PfGhosts
    G1 -.instance of.-> PfGhosts
    PacObj -.instance of.-> PfPac

    MapLoaderObj -.reads.-> CustomMaps
    MapLoaderObj -.reads.-> SecondMap
    Auto -.loads.-> Onnx
    Train -.trains via.-> PPO
